
@{
    ViewBag.Title = "Login";
}

<h2>Login</h2>

<form method="post" action="/Account/Login">

    <label>Username</label><br />
    <input type="text" name="Username" /><br /><br />

    <label>Password</label><br />
    <input type="password" name="Password" /><br /><br />

    <button type="submit">Login</button>

</form>

<p style="color:red;">
    @ViewBag.Error
</p>

</body>
</html>
